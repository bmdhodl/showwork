# Ledger files are integrity-chained JSONL. Never EOL-rewrite them: the
# chain hash is EOL-agnostic, but keeping bytes stable avoids noise.
.showwork/** -text
tests/fixtures/** -text

# Concurrent sessions in separate worktrees each append to the ledger. Union
# merge concatenates both branches instead of writing conflict markers; it
# preserves each side's line order, so every block's internal chain stays
# intact and the fork-tolerant audit accepts the result. See docs/concurrency.md.
.showwork/**/*.jsonl merge=union
.showwork/*.jsonl merge=union
